        println("Somme : ${n1 + n2}")
        println("Difference : ${n1 - n2}")
        println("Produit : ${n1 * n2}")
        if (n2 != 0.0) {
            println("Division : ${(n1 / n2)}")
        } else {
            println("Division : ERROR")
        }
    }

    fun exercice9() {
