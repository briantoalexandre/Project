        }
        println("factorielle : $j")
    }

    // partie 5
    fun exercice22() { // et exercice 21
        val j: Int = Random.nextInt(1, 100)
        var n: Int
        do {
            print("Nombre : ")
            n = readln().toInt()
            if (n > j) println("Trop grand")
            else if (n < j) println("Trop petit")

        } while (n != j)
        println("bravo")
    }

    fun exercice23() {
        var c: Int = 0
        print("Mot : ")
        val mot: String = readln()
        val voy: CharArray = charArrayOf('a', 'e', 'i', 'y', 'o', 'u')
        for (letter in mot) {
            if (letter.toChar() in voy) c++
        }
        println("Voyelles : $c")
    }

