            notes.add(note)
        }
        println("Moyenne : ${notes.average()}")
    }

    fun exercice27() {
        val villes: Array<String> = arrayOf("Paris", "Marseille", "Lyon", "Toulouse", "Nice")
        var ville: String
        do {
            print("Taper un nom de ville, ou stop : ")
            ville = readln().lowercase()
            if (villes.map { it.lowercase() }
                    .contains(ville)) println("Ville trouvée") else println("Ville pas trouvée")

        } while (ville != "stop")
    }
    // Partie 7

    fun exercice28() {
        fun userInput(): MutableList<Double> {
            val result: MutableList<Double> = mutableListOf()
            for (i in 1..10) {
                print("Note : ")
                result.add(readln().toDouble())
            }
            return result
        }

        var notes: MutableList<Double> = mutableListOf(12.0, 15.0, 9.0, 14.0, 16.0, 10.0, 18.0, 13.0, 11.0, 17.0)
        notes = userInput()
        println("Moyenne ${notes.sum() / notes.count()}")
        println("Note Max ${notes.max()}")
        println("Note Max ${notes.min()}")
    }

    fun exercice29() {
        fun inflation(price: Int = Random.nextInt(10, 30)): Double  {
            return price*(1/Random.nextInt(2,12).toDouble()+1.0)
        }

        fun insert() { // v = value
            var input2: String
            print("article : ")
            input2 = readln().lowercase()
            if (!produits.contains(input2)) produits.put(input2, mutableMapOf("price" to inflation(), "quantity" to 1.0))
            else produits.put(input2, mutableMapOf("price" to inflation(produits[input2]!!.get("price")!!.toInt()), "quantity" to produits[input2]!!["quantity"]!!.plus((1))))

        }
        fun select() {
            if (!produits.isEmpty()) {
                println("produits : ")
                produits.forEach { (k, v)->
                    println(" $k : $v")
                }
            } else println("empty")
        }
        var input: String
        do {
            print("cmd : ")
            input = readln().lowercase()
            if (input=="insert") insert()
            else if (input=="select") select()
            else println("commands :\n insert\n select")
        } while (!arrayOf("stop", "exit").contains(input))

    }

    fun exercice30() {
        fun insert() {
            print("insert : ")
            var input2: String
            input2 = readln().lowercase()
            if (!classmates.contains(input2)) classmates.add(input2)
            else println("Student is already in class")
        }
        fun select() {
            if (!classmates.isEmpty()) {
                println("classmates : ")
                classmates.forEach {
                    println(" $it")
                }
            } else println("empty")
        }
        fun find() {
            if (!classmates.isEmpty()) {
                print("find : ")
                var input3: String
                input3 = readln().lowercase()
                if (classmates.contains(input3)) println("Student found")
                else println("Student not found")
            } else println("empty")
        }
        var input: String
        do {
            print("cmd : ")
            input = readln().lowercase()
            if (input=="insert") insert()
            else if (input=="select") select()
            else if (input=="find") find()
            else println("commands :\n insert\n select\n find")
        } while (!arrayOf("stop", "exit").contains(input))
    }
    exercice30()
}

