        println("le plus grand est ${if (n1>n2) n1 else n2}")
    }

    fun exercice14() {
        print("Note : ")
        val note: Int = readln().toInt()
        if ((0 <= note) and (note <= 20)) {
            if (note < 15) print("Mentien : Aucune")
            else if (note < 17) print("Mentien : bien")
            else print("Mentien : tres bien")
        } else ("error")
    }

