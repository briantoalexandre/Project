            println("$n1 est négatif")
        } else {
            println("$n1 est neutre")
        }
    }

    fun exercice12() {
        print("age : ")
        val age: Int = readln().toInt()
        if (age > 0) {
            if (age < 18) {
                println("Vous êtes mineur")
